{
  "author": "MonoGame Foundation",
  "classifications": [
    "MonoGame", "Games", "Mobile", "Android", "iOS", "Desktop", "Windows", "Linux", "macOS"
  ],
  "name": "MonoGame 2D StartKit",
  "identity": "MonoGame.2D.StartKit",
  "groupIdentity": "MonoGame.2D.StartKit",
  "shortName": "mg2dstartkit",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "___SafeGameName___",
  "preferNameDirectory": true,
  "sources": [
    {
      "modifiers": [
        {
          "condition": "(OS == 'Linux')",
          "exclude": [
            "**/*.iOS.csproj",
            "**/iOS/**"
          ]
        }
      ]
    }
  ],
  "description": "A 2D MonoGame solution for all supported Mobile and Desktop platforms.",
    "postActions": [
        {
            "description": "Restore NuGet packages required by this project.",
            "manualInstructions": [
                {
                    "text": "Run 'dotnet restore'"
                }
            ],
            "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
            "continueOnError": true
        },
        {
            "description": "Remove iOS project from solution on Linux.",
            "actionId": "3A7C4B45-1F5D-4D3A-AE43-1F6DB2D6D2F9",
            "args": {
              "executable": "bash",
              "args": "-c \"dotnet sln '___SafeGameName___.sln' remove '___SafeGameName___.iOS/___SafeGameName___.iOS.csproj'\""
            },
            "condition": "(OS == 'Linux')",
            "continueOnError": true,
            "manualInstructions": [
              {
                "text": "Run: dotnet sln ___SafeGameName___.sln remove ___SafeGameName___.iOS/___SafeGameName___.iOS.csproj"
              }
            ]
        }
    ]
}